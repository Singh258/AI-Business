<section class="booking-section" id="booking">

    <div class="container booking-grid">

        <div class="booking-content">

            <span class="demo-label">

                BOOK A FREE DEMO

            </span>

            <h2>

                Let's Automate Your Dental Clinic

            </h2>

            <p>

                Fill out the form and we'll contact you with a personalized
                AI receptionist demo for your clinic.

            </p>

            <div class="booking-points">

                <div>

                    <i class="fa-solid fa-check"></i>

                    No Credit Card Required

                </div>

                <div>

                    <i class="fa-solid fa-check"></i>

                    Free Consultation

                </div>

                <div>

                    <i class="fa-solid fa-check"></i>

                    30 Minute Demo

                </div>

            </div>

        </div>

        <div class="booking-form-card">

            <form
                id="bookingForm"
                action="https://api.web3forms.com/submit"
                method="POST"
            >

                <input
                    type="hidden"
                    name="access_key"
                    value="YOUR_WEB3FORMS_ACCESS_KEY"
                >

                <input
                    type="hidden"
                    name="subject"
                    value="New AI Dental Receptionist Demo Request"
                >

                <input
                    type="hidden"
                    name="from_name"
                    value="DentalAI Landing Page"
                >

                <div class="form-group">

                    <label>Patient Name</label>

                    <input
                        type="text"
                        name="Patient Name"
                        placeholder="John Smith"
                        required
                    >

                </div>

                <div class="form-group">

                    <label>Phone Number</label>

                    <input
                        type="tel"
                        name="Phone Number"
                        placeholder="+1 555 123 4567"
                        required
                    >

                </div>

                <div class="form-group">

                    <label>Email Address</label>

                    <input
                        type="email"
                        name="Email"
                        placeholder="john@email.com"
                        required
                    >

                </div>

                <div class="form-group">

                    <label>Preferred Date</label>

                    <input
                        type="date"
                        name="Preferred Date"
                        required
                    >

                </div>

                <div class="form-group">

                    <label>Treatment</label>

                    <select
                        name="Treatment"
                        required
                    >

                        <option value="">
                            Select Treatment
                        </option>

                        <option>
                            Teeth Cleaning
                        </option>

                        <option>
                            Dental Implant
                        </option>

                        <option>
                            Root Canal
                        </option>

                        <option>
                            Teeth Whitening
                        </option>

                        <option>
                            General Consultation
                        </option>

                    </select>

                </div>

                <button
                    type="submit"
                    class="btn btn-primary submit-btn"
                >

                    <span class="btn-text">

                        Book Free Demo

                    </span>

                    <span class="loader"></span>

                </button>

            </form>

        </div>

    </div>

</section>

