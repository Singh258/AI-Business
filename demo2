:root{

--primary:#2563eb;
--primary-dark:#1d4ed8;
--secondary:#06b6d4;
--success:#22c55e;
--dark:#0f172a;
--dark-2:#1e293b;
--text:#334155;
--light:#f8fafc;
--border:#e2e8f0;
--white:#ffffff;

--shadow:0 20px 60px rgba(15,23,42,.08);
--shadow-lg:0 30px 80px rgba(37,99,235,.15);

--radius:20px;
--transition:.35s ease;

}

*{
margin:0;
padding:0;
box-sizing:border-box;
}

html{
scroll-behavior:smooth;
}

body{

font-family:"Inter",sans-serif;
background:#f8fbff;
color:var(--text);
overflow-x:hidden;

}

a{
text-decoration:none;
}

img{
max-width:100%;
display:block;
}

ul{
list-style:none;
}

.container{

width:min(1180px,92%);
margin:auto;

}

/*========================*/

.bg-blur{

position:fixed;
border-radius:50%;
filter:blur(120px);
z-index:-1;

}

.blur-1{

width:450px;
height:450px;
background:#60a5fa;
top:-120px;
left:-150px;
opacity:.18;

}

.blur-2{

width:420px;
height:420px;
background:#22d3ee;
bottom:-180px;
right:-100px;
opacity:.15;

}

/*========================*/

header{

position:sticky;
top:0;
z-index:999;

background:rgba(255,255,255,.75);

backdrop-filter:blur(20px);

border-bottom:1px solid rgba(226,232,240,.7);

}

nav{

height:80px;

display:flex;
align-items:center;
justify-content:space-between;

}

.logo{

display:flex;
align-items:center;
gap:12px;

font-size:1.35rem;
font-weight:800;

color:var(--dark);

}

.logo-icon{

width:48px;
height:48px;

border-radius:14px;

background:linear-gradient(135deg,#2563eb,#06b6d4);

display:flex;
align-items:center;
justify-content:center;

color:#fff;
font-size:20px;

box-shadow:var(--shadow);

}

.nav-links{

display:flex;
align-items:center;
gap:34px;

}

.nav-links a{

font-weight:600;
color:var(--dark);

transition:var(--transition);

}

.nav-links a:hover{

color:var(--primary);

}

.mobile-menu{

display:none;

font-size:26px;
cursor:pointer;

}

/*========================*/

.btn{

display:inline-flex;
align-items:center;
justify-content:center;

padding:15px 28px;

border-radius:14px;

font-weight:700;

transition:var(--transition);

cursor:pointer;

border:none;

}

.btn-primary{

background:linear-gradient(135deg,#2563eb,#0ea5e9);

color:#fff;

box-shadow:0 18px 35px rgba(37,99,235,.28);

}

.btn-primary:hover{

transform:translateY(-4px);

box-shadow:0 22px 45px rgba(37,99,235,.35);

}

.btn-secondary{

background:#fff;

color:var(--dark);

border:1px solid var(--border);

}

.btn-secondary:hover{

transform:translateY(-4px);

}

/*========================*/

.hero{

padding:90px 0;

}

.hero-grid{

display:grid;
grid-template-columns:1fr 520px;
gap:70px;
align-items:center;

}

.badge{

display:inline-flex;
align-items:center;
gap:10px;

padding:10px 18px;

border-radius:999px;

background:#e0f2fe;

color:#0369a1;

font-size:.9rem;
font-weight:700;

margin-bottom:22px;

}

.hero-left h1{

font-size:4rem;
line-height:1.08;
font-weight:900;
color:var(--dark);

margin-bottom:24px;

}

.hero-left h1 span{

display:block;

background:linear-gradient(135deg,#2563eb,#06b6d4);

-webkit-background-clip:text;
-webkit-text-fill-color:transparent;

}

.hero-left p{

font-size:1.1rem;

line-height:1.8;

margin-bottom:34px;

max-width:620px;

}

.hero-buttons{

display:flex;
gap:18px;
flex-wrap:wrap;

margin-bottom:45px;

}

.hero-stats{

display:grid;
grid-template-columns:repeat(3,1fr);
gap:18px;

}

.stat-card{

background:#fff;

padding:28px;

border-radius:20px;

box-shadow:var(--shadow);

text-align:center;

}

.stat-card h2{

font-size:2rem;
color:var(--primary);

margin-bottom:8px;

}

.stat-card p{

margin:0;
font-size:.95rem;

}

.ai-window{

background:#fff;

border-radius:28px;

overflow:hidden;

box-shadow:var(--shadow-lg);

border:1px solid var(--border);

}

.window-top{

padding:18px 24px;

display:flex;
justify-content:space-between;
align-items:center;

background:#eff6ff;

}

.dots{

display:flex;
gap:8px;

}

.dots span{

width:12px;
height:12px;

border-radius:50%;

background:#94a3b8;

}

.chat-area{

padding:30px;

display:flex;
flex-direction:column;
gap:24px;

min-height:520px;

}

.message{

display:flex;
gap:12px;
align-items:flex-end;

}

.message.user{

justify-content:flex-end;

}

.avatar{

width:46px;
height:46px;

border-radius:50%;

display:flex;
align-items:center;
justify-content:center;

background:linear-gradient(135deg,#2563eb,#06b6d4);

color:#fff;

flex-shrink:0;

}

.bubble{

max-width:300px;

padding:16px 18px;

border-radius:18px;

background:#f1f5f9;

line-height:1.6;

}

.message.user .bubble{

background:#2563eb;
color:#fff;

}
.typing{
display:flex;
gap:6px;
margin-left:58px;
}

.typing span{
width:10px;
height:10px;
border-radius:50%;
background:#94a3b8;
animation:typing 1.2s infinite;
}

.typing span:nth-child(2){
animation-delay:.2s;
}

.typing span:nth-child(3){
animation-delay:.4s;
}

@keyframes typing{
0%,100%{
opacity:.3;
transform:translateY(0);
}
50%{
opacity:1;
transform:translateY(-6px);
}
}

/*========================*/

.brands{
padding:30px 0 70px;
}

.brands p{
text-align:center;
font-weight:700;
letter-spacing:1px;
color:#64748b;
margin-bottom:30px;
}

.brand-grid{
display:grid;
grid-template-columns:repeat(5,1fr);
gap:20px;
}

.brand-grid div{
background:#fff;
padding:22px;
border-radius:18px;
text-align:center;
font-weight:700;
box-shadow:var(--shadow);
}

/*========================*/

.features,
.how-it-works,
.demo-section,
.booking-section{
padding:100px 0;
}

.section-title{
text-align:center;
max-width:720px;
margin:0 auto 60px;
}

.section-title span{
display:inline-block;
padding:8px 16px;
border-radius:999px;
background:#dbeafe;
color:#2563eb;
font-weight:700;
font-size:.85rem;
margin-bottom:18px;
}

.section-title h2{
font-size:2.8rem;
color:var(--dark);
margin-bottom:18px;
}

.section-title p{
line-height:1.8;
}

/*========================*/

.feature-grid{
display:grid;
grid-template-columns:repeat(3,1fr);
gap:28px;
}

.feature-card{
background:#fff;
padding:36px;
border-radius:24px;
box-shadow:var(--shadow);
transition:var(--transition);
}

.feature-card:hover{
transform:translateY(-10px);
}

.feature-card .icon{
width:70px;
height:70px;
border-radius:18px;
display:flex;
align-items:center;
justify-content:center;
font-size:28px;
background:linear-gradient(135deg,#2563eb,#06b6d4);
color:#fff;
margin-bottom:24px;
}

.feature-card h3{
margin-bottom:14px;
color:var(--dark);
}

.feature-card p{
line-height:1.8;
}

/*========================*/

.steps{
display:grid;
grid-template-columns:repeat(3,1fr);
gap:28px;
}

.step{
background:#fff;
padding:40px;
border-radius:24px;
box-shadow:var(--shadow);
}

.step-number{
font-size:3rem;
font-weight:900;
color:#2563eb;
margin-bottom:20px;
}

.step h3{
margin-bottom:16px;
color:var(--dark);
}

.step p{
line-height:1.8;
}

/*========================*/

.demo-grid{
display:grid;
grid-template-columns:1fr 420px;
gap:70px;
align-items:center;
}

.demo-label{
display:inline-block;
padding:8px 18px;
background:#cffafe;
color:#0891b2;
border-radius:999px;
font-weight:700;
margin-bottom:18px;
}

.demo-left h2{
font-size:2.8rem;
color:var(--dark);
margin-bottom:22px;
}

.demo-left p{
line-height:1.8;
margin-bottom:30px;
}

.demo-list{
display:flex;
flex-direction:column;
gap:18px;
}

.demo-list li{
display:flex;
align-items:center;
gap:12px;
font-weight:600;
}

.demo-list i{
color:var(--success);
}

.voice-card{
background:#fff;
padding:50px;
border-radius:30px;
box-shadow:var(--shadow-lg);
text-align:center;
}

.voice-circle{
width:120px;
height:120px;
border-radius:50%;
margin:auto;
display:flex;
align-items:center;
justify-content:center;
font-size:46px;
color:#fff;
background:linear-gradient(135deg,#2563eb,#06b6d4);
animation:pulse 2s infinite;
}

@keyframes pulse{
0%{box-shadow:0 0 0 0 rgba(37,99,235,.35);}
70%{box-shadow:0 0 0 28px rgba(37,99,235,0);}
100%{box-shadow:0 0 0 0 rgba(37,99,235,0);}
}

.voice-card h3{
margin-top:28px;
margin-bottom:10px;
color:var(--dark);
}

.voice-status{
font-weight:600;
color:#64748b;
margin-bottom:30px;
}

.wave{
display:flex;
justify-content:center;
align-items:flex-end;
gap:8px;
height:70px;
}

.wave span{
width:8px;
border-radius:999px;
background:#2563eb;
animation:wave 1s infinite ease-in-out;
}

.wave span:nth-child(1){height:18px;}
.wave span:nth-child(2){height:40px;animation-delay:.1s;}
.wave span:nth-child(3){height:60px;animation-delay:.2s;}
.wave span:nth-child(4){height:34px;animation-delay:.3s;}
.wave span:nth-child(5){height:20px;animation-delay:.4s;}

@keyframes wave{
0%,100%{transform:scaleY(.6);}
50%{transform:scaleY(1.2);}
}

/*========================*/

.booking-grid{
display:grid;
grid-template-columns:1fr 470px;
gap:60px;
align-items:center;
}

.booking-content h2{
font-size:2.8rem;
color:var(--dark);
margin-bottom:20px;
}

.booking-content p{
line-height:1.8;
margin-bottom:30px;
}

.booking-points{
display:flex;
flex-direction:column;
gap:16px;
}

.booking-points div{
display:flex;
align-items:center;
gap:12px;
font-weight:600;
}

.booking-points i{
color:var(--success);
}

.booking-form-card{
background:#fff;
padding:40px;
border-radius:28px;
box-shadow:var(--shadow-lg);
}

.form-group{
margin-bottom:22px;
}

.form-group label{
display:block;
font-weight:600;
margin-bottom:8px;
color:var(--dark);
}

.form-group input,
.form-group select{
width:100%;
padding:15px 16px;
border:1px solid var(--border);
border-radius:14px;
font-size:1rem;
font-family:inherit;
outline:none;
transition:var(--transition);
}

.form-group input:focus,
.form-group select:focus{
border-color:#2563eb;
box-shadow:0 0 0 4px rgba(37,99,235,.12);
}
.submit-btn{
width:100%;
position:relative;
overflow:hidden;
}

.loader{
display:none;
width:22px;
height:22px;
border:3px solid rgba(255,255,255,.35);
border-top-color:#fff;
border-radius:50%;
animation:spin .8s linear infinite;
margin-left:12px;
}

.submit-btn.loading .loader{
display:inline-block;
}

.submit-btn.loading .btn-text{
opacity:.7;
}

@keyframes spin{
to{
transform:rotate(360deg);
}
}

/*========================*/

.success-popup{
position:fixed;
inset:0;
background:rgba(15,23,42,.55);
display:flex;
align-items:center;
justify-content:center;
padding:20px;
opacity:0;
visibility:hidden;
transition:.3s ease;
z-index:2000;
}

.success-popup.show{
opacity:1;
visibility:visible;
}

.popup-card{
background:#fff;
width:100%;
max-width:420px;
border-radius:28px;
padding:42px;
text-align:center;
box-shadow:var(--shadow-lg);
animation:popup .35s ease;
}

@keyframes popup{
from{
opacity:0;
transform:translateY(30px) scale(.96);
}
to{
opacity:1;
transform:translateY(0) scale(1);
}
}

.success-icon{
width:90px;
height:90px;
margin:0 auto 24px;
border-radius:50%;
display:flex;
align-items:center;
justify-content:center;
background:#dcfce7;
color:#16a34a;
font-size:42px;
}

.popup-card h3{
font-size:2rem;
color:var(--dark);
margin-bottom:12px;
}

.popup-card p{
line-height:1.8;
margin-bottom:30px;
}

/*========================*/

footer{
background:#0f172a;
color:#fff;
padding:70px 0;
margin-top:80px;
}

.footer-content{
display:flex;
justify-content:space-between;
align-items:flex-start;
gap:50px;
flex-wrap:wrap;
}

.footer-logo p{
margin-top:20px;
max-width:360px;
line-height:1.8;
color:#cbd5e1;
}

.footer-links{
display:flex;
gap:30px;
flex-wrap:wrap;
}

.footer-links a{
color:#e2e8f0;
transition:.3s;
}

.footer-links a:hover{
color:#38bdf8;
}

/*========================*/

@media (max-width:1100px){

.hero-grid,
.demo-grid,
.booking-grid{
grid-template-columns:1fr;
}

.hero-right,
.demo-right{
max-width:620px;
margin:auto;
}

.feature-grid{
grid-template-columns:repeat(2,1fr);
}

.steps{
grid-template-columns:1fr;
}

.brand-grid{
grid-template-columns:repeat(3,1fr);
}

}

@media (max-width:768px){

.nav-links,
nav .btn{
display:none;
}

.mobile-menu{
display:block;
}

.hero{
padding:70px 0;
}

.hero-left h1{
font-size:2.8rem;
}

.section-title h2,
.demo-left h2,
.booking-content h2{
font-size:2rem;
}

.hero-stats,
.feature-grid,
.brand-grid{
grid-template-columns:1fr;
}

.chat-area{
min-height:auto;
}

.booking-form-card{
padding:28px;
}

.popup-card{
padding:32px 24px;
}

.footer-content{
flex-direction:column;
}

}

@media (max-width:480px){

.hero-left h1{
font-size:2.2rem;
}

.btn{
width:100%;
}

.hero-buttons{
flex-direction:column;
}

.stat-card{
padding:22px;
}

.voice-card{
padding:35px 25px;
}

.voice-circle{
width:90px;
height:90px;
font-size:34px;
}

}

/*==========================
END OF STYLE.CSS
